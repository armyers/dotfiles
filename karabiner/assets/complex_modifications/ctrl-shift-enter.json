{
  "title": "ctrl-shift-enter to CMD-enter",
  "rules": [
    {
      "description": "ctrl-shift-enter to CMD-enter",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "modifiers": {
              "mandatory": [
                "left_control",
                "left_shift"
              ]
            },
            "key_code": "return_or_enter"
          },
          "to": [
            {
              "repeat": true,
              "key_code": "return_or_enter",
              "modifiers": [
                "left_command"
              ]
            }
          ]
        }
      ]
    }
  ]
}
