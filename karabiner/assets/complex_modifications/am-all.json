{
  "title": "All keyboard mappings for Allen Myers",
  "rules": [
    {
      "description": "ctrl-shift-c to copy to clipboard",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "modifiers": {
              "mandatory": [
                "left_control",
                "left_shift"
              ]
            },
            "key_code": "c"
          },
          "to": [
            {
              "repeat": true,
              "key_code": "c",
              "modifiers": [
                "left_command"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "ctrl-shift-enter to CMD-enter",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "modifiers": {
              "mandatory": [
                "left_control",
                "left_shift"
              ]
            },
            "key_code": "return_or_enter"
          },
          "to": [
            {
              "repeat": true,
              "key_code": "return_or_enter",
              "modifiers": [
                "left_command"
              ]
            }
          ]
        }
      ]
    },
