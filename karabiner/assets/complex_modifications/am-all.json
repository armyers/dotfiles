                "left_control",
                "left_command"
              ]
            },
            "key_code": "j"
          },
          "to": [
            {
              "mouse_key": {
                "vertical_wheel": -60
              }
            }
          ]
        }
      ]
    },
    {
      "description": "ctrl-cmd-k to scroll wheel up",
      "manipulators": [
        {
          "type": "basic",
