<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.user.kanata-logitech</string>
	<key>ProgramArguments</key>
	<array>
		<string>/opt/homebrew/opt/kanata/bin/kanata</string>
		<string>--no-wait</string>
		<string>--cfg</string>
		<string>/Users/allenmyers/.config/kanata/kanata-logitech.kbd</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>StandardErrorPath</key>
	<string>/opt/homebrew/var/log/kanata-logitech.log</string>
	<key>StandardOutPath</key>
	<string>/opt/homebrew/var/log/kanata-logitech.log</string>
	<key>WorkingDirectory</key>
	<string>/Users/allenmyers</string>
	<key>EnvironmentVariables</key>
	<dict>
		<key>PATH</key>
		<string>/opt/homebrew/bin:/opt/homebrew/sbin:/usr/bin:/bin:/usr/sbin:/sbin</string>
	</dict>
</dict>
</plist>
