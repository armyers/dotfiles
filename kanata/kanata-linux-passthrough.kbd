;; Passthrough config — pair for kanata-linux.kbd (Linux/i3).
;; Loaded as the second --cfg arg. Hold caps 3s here to return to the
;; main config. Everything else passes through untouched.

(defcfg
  concurrent-tap-hold yes
  process-unmapped-keys yes
  linux-dev-names-include (
    "TODO-device-name"  ;; mirror whatever kanata-linux.kbd is using
  )
  log-layer-changes no
)

(defsrc
  caps
)

(defalias
  cap (tap-hold 200 3000 esc lrnx)
)

(deflayer base
  @cap
)
