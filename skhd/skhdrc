# ----- ~/.config/skhd/skhdrc -----
# No alias; we spell out cmd+alt+ctrl+shift explicitly.

# Restart both kanata daemons (post-sleep recovery). Uses osascript so macOS
# shows its native auth dialog (TouchID / password) for the sudo step.
cmd + ctrl + alt + shift - r : osascript -e 'do shell script "/Users/allenmyers/.dotfiles/kanata/reset-daemons.sh" with administrator privileges' -e 'display notification "Both daemons restarted" with title "Kanata Reset"'

# Tomahawk56 cheatsheet popup (SVG keymap)
ctrl + alt - t : /Users/allenmyers/code/armyers/tomahawk56-zmk-config/cheatsheet

# ─── Karabiner→Kanata migration shortcuts ───────────────────────────────
# Trigger via Kanata HRM (s=ctrl, a=shift, d=cmd, f=alt) or physical fn (=ctrl)

# Arrow keys via ctrl+shift+h/j/k/l (HRM s+a+h/j/k/l or l+;+h/j/k/l)
ctrl + shift - h : skhd -k "left"
ctrl + shift - j : skhd -k "down"
ctrl + shift - k : skhd -k "up"
ctrl + shift - l : skhd -k "right"

# Open Gemini in new Chrome window (ctrl+shift+g, HRM s+a+g)
ctrl + shift - g : open -na 'Google Chrome' --args --new-window 'https://gemini.google.com'

# Toggle AeroSpace (s is HRM ctrl key — trigger via physical fn+shift+s)
ctrl + shift - s : pgrep -x AeroSpace > /dev/null && osascript -e 'tell application "AeroSpace" to quit' || open -a AeroSpace

# Cycle audio devices (d is HRM cmd key — trigger via physical fn+shift+d)
ctrl + shift - d : /Users/allenmyers/.local/bin/cycle-audio.sh
